<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <Package
        Name="Bitbucket CLI"
        Manufacturer="Pegasus Heavy Industries"
        Version="0.3.17"
        UpgradeCode="12345678-1234-1234-1234-123456789012"
        Scope="perMachine"
        InstallerVersion="450"
        Compressed="yes"
        Language="1033">

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of Bitbucket CLI is already installed. Setup will now exit." />

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1" />
        <Property Id="DiskPrompt" Value="Bitbucket CLI Installation" />

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="APPLICATIONFOLDER" Name="BitbucketCLI">
                <Component Id="MainExecutable" Bitness="always64">
                    <File
                        Id="bitbucketEXE"
                        Name="bitbucket.exe"
                        Source="target\x86_64-pc-windows-msvc\release\bitbucket.exe"
                        KeyPath="yes" />
                    <Environment
                        Id="PATH"
                        Name="PATH"
                        Value="[APPLICATIONFOLDER]"
                        Permanent="no"
                        Part="last"
                        Action="set"
                        System="yes" />
                </Component>
                <Component Id="License" Bitness="always64">
                    <File
                        Id="LicenseFile"
                        Name="LICENSE.txt"
                        Source="LICENSE"
                        KeyPath="yes" />
                </Component>
                <Component Id="Readme" Bitness="always64">
                    <File
                        Id="ReadmeFile"
                        Name="README.md"
                        Source="README.md"
                        KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <Feature
            Id="Complete"
            Title="Bitbucket CLI"
            Description="The complete Bitbucket CLI package."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER">
            <ComponentRef Id="MainExecutable" />
            <ComponentRef Id="License" />
            <ComponentRef Id="Readme" />
        </Feature>

        <Icon Id="ProductICO" SourceFile="packaging\windows\icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="ProductICO" />
        <Property Id="ARPHELPLINK" Value="https://github.com/pegasusheavy/bitbucket-cli" />

        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="APPLICATIONFOLDER" />
        <Property Id="WIXUI_INSTALLDIR" Value="APPLICATIONFOLDER" />

    </Package>
</Wix>
